{
    "functions": {
      "api/index.ts": {
        "includeFiles": "{node_modules/.prisma/client/**,prisma/schema.prisma}"
      }
    },
    "rewrites": [
      {
        "source": "/api/:path*",
        "destination": "/api/index.ts"
      },
      {
        "source": "/uploads/:path*",
        "destination": "/api/index.ts"
      },
      {
        "source": "/:path*",
        "destination": "/index.html"
      }
    ]
  }
  